[app]

# (str) Source code where the main.py live
source.dir = ./

# (str) Application title
title = Xenon

# (str) Package name
package.name = xenoncheat

# (str) Package domain (reverse domain)
package.domain = org.xenon

# (str) Version
version = 1.1

# (list) Requirements
requirements = python3,kivy

# (str) Orientation
orientation = portrait

# (bool) Fullscreen
fullscreen = 0

# (int) Android API level
android.api = 31

# (int) Minimum Android API level
android.minapi = 21

# (str) Android NDK version
android.ndk = 23b

# (list) Android architectures
android.arch = arm64-v8a

# (list) Android permissions
android.permissions = INTERNET

# (str) Android release artifact
android.release_artifact = apk

[buildozer]

# (int) Log level
log_level = 2

# (bool) Warn on root
warn_on_root = 1
